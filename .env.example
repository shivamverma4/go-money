# Copy this to .env and fill in your values
# .env is gitignored — never commit it

DATABASE_URL=postgres://go_money:go_money_secret@localhost:5432/go_money?sslmode=disable
PORT=8080

# Set to true to auto-apply migrations on server startup
RUN_MIGRATIONS=false
MIGRATIONS_PATH=./migrations

# Set to true to serve frontend/dist from the Go server (used in Docker)
SERVE_STATIC=false
STATIC_DIR=./frontend/dist

CURRENCY_CODE=INR
CURRENCY_SYMBOL=₹
CURRENCY_SUBUNIT_NAME=paise

CORS_ORIGINS=http://localhost:5173

# Used by backend integration tests
TEST_DATABASE_URL=postgres://postgres:password@localhost:5432/go_money_test?sslmode=disable
